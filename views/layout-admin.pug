doctype html
html(lang="id")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= title || 'Admin - TravelGo'
    link(rel="stylesheet" href="/css/admin.css")
    script.
      (function() {
        const savedTheme = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
      })();
  body
    header.navbar
      .container(style="display: flex; align-items: center; justify-content: space-between; width: 100%;")
        h1 TravelGo Admin
        div(style="display: flex; align-items: center; gap: 1rem;")
          button.theme-toggle-btn(type="button") ☀️
          a.btn.btn-logout(href="/logout") Logout
    aside.sidebar
      ul
        li: a(href="/admin/dashboard") Dashboard
        li: a(href="/admin/schedules") Jadwal
        li: a(href="/admin/vehicles") Kendaraan
        li: a(href="/admin/bookings") Pemesanan
        li: a(href="/admin/cancellation-requests") Pembatalan
        li: a(href="/admin/reschedule-requests") Reschedule
        li: a(href="/admin/notifications") Notifikasi
    main.content
      block content

    script(src="/js/theme-toggle.js")

