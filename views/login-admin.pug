extends layout

block content
  .glass-card.form-container
    h2 Login Admin
    if error
      p(style="color: #ef4444; text-align: center; margin-bottom: 1rem; font-size: 0.9rem;") #{error}
    form(action="/login-admin" method="POST")
      .form-group
        label(for="email") Email
        input#email(type="email" name="email" placeholder="Masukkan email admin" required)
      .form-group
        label(for="username") Username
        input#username(type="text" name="username" placeholder="Masukkan username admin" required)
      .form-group
        label(for="password") Password
        input#password(type="password" name="password" placeholder="Masukkan password admin" required)
      button.btn.btn-large(type="submit" style="width: 100%") Masuk sebagai Admin
