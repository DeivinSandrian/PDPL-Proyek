extends layout

block content
  .glass-card.form-container
    h2 Login Pelanggan
    if error
      p(style="color: #ef4444; text-align: center; margin-bottom: 1rem; font-size: 0.9rem;") #{error}
    form(action="/login-customer" method="POST")
      .form-group
        label(for="email") Email
        input#email(type="email" name="email" placeholder="Masukkan email Anda" required)
      .form-group
        label(for="username") Username
        input#username(type="text" name="username" placeholder="Masukkan username Anda" required)
      .form-group
        label(for="password") Password
        input#password(type="password" name="password" placeholder="Masukkan password" required)
      button.btn.btn-large(type="submit" style="width: 100%") Masuk
    p(style="text-align: center; margin-top: 1.5rem; color: var(--text-muted);") Belum punya akun? 
      a(href="/register" style="color: var(--primary); font-weight: 600; text-decoration: none;") Daftar di sini
